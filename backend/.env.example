# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=esg_experiment
DB_USER=postgres
DB_PASSWORD=postgres

# Server Configuration
PORT=5001
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5001

# Application Settings
APP_NAME=ESG Experiment App
APP_VERSION=1.0.0

# Security (for production, generate secure random strings)
SESSION_SECRET=your_session_secret_here_change_in_production
JWT_SECRET=your_jwt_secret_here_change_in_production

# Performance Tuning (optional)
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# For production deployment with external services
# DATABASE_URL=postgresql://username:password@host:port/database

# Example for Supabase (free tier)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Example for Railway
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-RAILWAY-URL].railway.app:5432/railway

# Example for Neon
# DATABASE_URL=postgresql://[YOUR-USERNAME]:[YOUR-PASSWORD]@[YOUR-PROJECT-ID].[YOUR-REGION].aws.neon.tech/neondb

# Note: In production, DATABASE_URL will override individual DB_* variables
# if using services like Railway, Render, Heroku, etc.